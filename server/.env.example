# Between Us — Environment Variables
# Copy to .env and fill in values
# ⚠️ Never commit .env to git

# ─── Required in ALL environments ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/betweenus"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-min-32-chars-random-string"
JWT_REFRESH_SECRET="change-me-different-min-32-chars-random-string"
CLIENT_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Required in PRODUCTION ───────────────────────────────────────────────────
CONTACT_HASH_SECRET="change-me-min-32-chars-random-string"

# ─── Storage (Cloudflare R2 / AWS S3) ────────────────────────────────────────
STORAGE_ENDPOINT="https://account.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY="your-access-key"
STORAGE_SECRET_KEY="your-secret-key"
STORAGE_BUCKET="betweenus"
STORAGE_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─── Stripe (only when payments are active) ──────────────────────────────────
# Use sk_test_... in development, sk_live_... in production (after legal review)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PREMIUM="price_..."
STRIPE_PRICE_COUPLE="price_..."

# ─── Email (Resend or SMTP) ───────────────────────────────────────────────────
# Required for email verification to work in production
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="your-resend-api-key"
EMAIL_FROM="noreply@betweenus.app"

# ─── Optional ─────────────────────────────────────────────────────────────────
BETA_CLOSED="false"         # Set to "true" to require invite code on registration
ADMIN_EMAILS=""             # Comma-separated fallback admin emails (use adminRole in DB instead)

# 3.8 Privacy Hardening
CSP_REPORT_ONLY="false"

# 3.5 Contact hash key rotation (see ContactHashService)
CONTACT_HASH_SECRET_V2=""
CONTACT_HASH_ACTIVE_VERSION="1"

# 3.7 Sentry
SENTRY_DSN=""

# 4.2 — Profile Architecture
GROUP_PROFILES_ENABLED="true"

# 11.5/11.5.5 — Intelligent Recommendations (Layer 3, shadow mode by default)
# Production-recommended initial state: shadow ON, ranking OFF — computes
# and logs what the new ranker WOULD do, but Discovery keeps serving the
# current (Layer 1+2) ranking untouched until there's a real data period
# to review (see 11.11 shadow-analysis / guardrails before ever flipping
# the second flag). Deliberately env-only, not admin-UI-togglable — a
# deploy-time decision, not a mid-incident click.
INTELLIGENT_RECOMMENDATIONS_SHADOW_MODE="true"
INTELLIGENT_RECOMMENDATIONS_ENABLED="false"
# How long RecommendationRankingLog rows are kept before the daily cleanup
# job prunes them (see recommendationLogCleanupJob.ts).
RECOMMENDATION_LOG_RETENTION_DAYS="90"
# 11.5.7 — minimum sample size (profiles per cohort / logged ranking pairs)
# before shadow-analysis/guardrail metrics are treated as reliable enough
# to act on. Below this, dataSufficient=false and recommendDisable is
# forced to false regardless of what the raw numbers look like.
RECOMMENDATION_MIN_SAMPLE_SIZE="30"

# Security follow-up — Web Push (VAPID). Previously had a REAL key pair
# hardcoded as a fallback in server/src/lib/webpush.ts — fixed to require
# these explicitly (fails to send push, does not crash the app, if unset).
# Generate a new pair with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@betweenus.app"

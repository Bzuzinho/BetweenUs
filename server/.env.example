# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
CLIENT_URL=https://betweenus-production.up.railway.app

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/between_us"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="between-us-jwt-2026-xK9mPqR4nL8vT2w"
JWT_REFRESH_SECRET="between-us-refresh-2026-yH7jNsW5eQ3c"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of admin emails
ADMIN_EMAILS="ricardo.jgvf@gmail.com"

# ─── Email (Resend — https://resend.com) ──────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM="Between Us <noreply@betweenus.app>"

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=between-us-media
STORAGE_PUBLIC_URL=https://media.betweenus.app

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_COUPLE=price_...

# ─── Beta Fechado ─────────────────────────────────────────────────────────────
# Definir como "true" para ativar o sistema de convites no registo
BETA_CLOSED=false

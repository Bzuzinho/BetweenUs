{
  "name": "between-us-server",
  "version": "2.3.0",
  "private": true,
  "scripts": {
    "start": "npx prisma db push --accept-data-loss && node -r ts-node/register/transpile-only src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "dotenv -e .env.test -- jest --runInBand --forceExit",
    "test:coverage": "dotenv -e .env.test -- jest --runInBand --forceExit --coverage",
    "test:watch": "dotenv -e .env.test -- jest --watch --runInBand",
    "db:migrate": "npx prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.11",
    "redis": "^4.6.13",
    "sharp": "^0.33.2",
    "socket.io": "^4.7.4",
    "stripe": "^14.21.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "prisma": "^5.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.11.20",
    "@types/uuid": "^9.0.8",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2"
  }
}
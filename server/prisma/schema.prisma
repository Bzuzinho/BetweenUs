// Between Us — Prisma Schema v4
// Roles reais + AdminAction completo + ConsentCheck + novas features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  BANNED
  DELETED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
  FINANCE
  CONTENT_REVIEWER
}

enum ProfileType {
  INDIVIDUAL
  COUPLE
  GROUP
}

enum ProfileMemberStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  HIDDEN
  SUSPENDED
}

// 4.5 — Sprint 4 evaluated migrating this to a data-driven catalog table
// (like Gender/Orientation/Intention/Boundary) and decided AGAINST it for
// now:
//   - Unlike gender/orientation, relationship status genuinely drives
//     behavior today (discovery.ts calcScore's compatMap keys off these
//     exact enum values). A data-driven catalog would need that
//     compatibility matrix to also become data-driven to avoid the
//     classic trap of "admin renames a row, matching logic silently
//     breaks" — a bigger change than a label-editing catalog.
//   - The spec's own caution applies directly: "não introduzir
//     complexidade sem impacto claro no produto." Admin being able to
//     edit a label/description/sortOrder here has real but modest value;
//     it doesn't yet justify decoupling the compatibility logic from the
//     enum.
// Also evaluated adding OPEN_RELATIONSHIP, HIERARCHICAL_POLY,
// NON_HIERARCHICAL_POLY, SOLO_POLY as new values. Not added: OPEN already
// exists and overlaps OPEN_RELATIONSHIP conceptually, and the poly
// variants are a "relationship model" distinction (how poly, structurally)
// layered on top of "relationship status" (single/committed/married/etc)
// — conflating the two into one flat enum is exactly what the spec asks
// to avoid ("separar relationship status de relationship model"). The
// clean way to add poly-structure detail is a SEPARATE field/catalog, not
// more enum values here — deferred until there's a concrete product need
// for it, per the same anti-complexity caution above.
enum RelationshipStatus {
  SINGLE
  COMMITTED
  MARRIED
  OPEN
  POLYAMOROUS
  COUPLE_CURIOUS
  COUPLE_LIBERAL
  OTHER
}

enum DiscretionLevel {
  MAXIMUM
  SELECTIVE
  OPEN
}

enum ProfileVisibility {
  PUBLIC
  MATCHES_ONLY
  INVISIBLE
}

enum PhotoVisibility {
  PUBLIC
  BLURRED
  PRIVATE_AFTER_MATCH
  PRIVATE_AFTER_APPROVAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum BoundaryPreference {
  YES
  MAYBE
  NO
}

enum ActionType {
  LIKE
  PASS
  SUPER_LIKE
  BLOCK
  REPORT
}

enum MatchStatus {
  PENDING
  PENDING_COUPLE_APPROVAL
  ACTIVE
  PAUSED
  ENDED
  BLOCKED
}

enum CoupleStatus {
  PENDING_PARTNER
  ACTIVE
  PAUSED
  SEPARATED
  DISABLED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
  CONSENT_REQUEST
  PHOTO_UNLOCK_REQUEST
}

enum ConversationType {
  ONE_TO_ONE
  COUPLE_GROUP
  PRIVATE_ROOM
}

enum ReportReason {
  FAKE_PROFILE
  HARASSMENT
  OFFENSIVE_CONTENT
  MINOR
  NON_CONSENSUAL_IMAGE
  SPAM
  THREAT
  COERCION
  REVENGE_PORN
  DOXXING
  PROSTITUTION_OR_ESCORT
  PAID_SEXUAL_SERVICES
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
  ESCALATED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  COUPLE_PREMIUM
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIALING
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// 3.4 — was a free-form String defaulting to "selfie"; no taxonomy, no
// public badge exposure. Kept 1-per-user cardinality (Verification.userId
// stays @unique) to avoid destabilizing UserActivationService/
// EligibilityService, both built in Sprint 2.5 around a single verification
// record per user. True multi-type verification (tracking SELFIE and
// ID_DOCUMENT simultaneously for one user) would need Verification.userId
// to become non-unique + those two services updated accordingly — flagged
// as follow-up, out of proportion to what this sprint asked for.
enum VerificationType {
  SELFIE
  ID_DOCUMENT
  VIDEO
}

enum ConsentType {
  TERMS
  PRIVACY_POLICY
  SENSITIVE_DATA
  MARKETING
  LOCATION
  CONTACT_HASHING
}

enum NotificationMode {
  NORMAL
  DISCREET
  SILENT
}

enum ConsentCheckStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ConsentCheckPhase {
  MATCH
  CHAT
  PHOTO_REQUEST
  FACE_REVEAL
  VIDEO_CALL
  MEETING_PROPOSAL
  SAFETY_CHECKIN
}

enum PhotoAccessStatus {
  PENDING
  APPROVED
  DECLINED
  REVOKED
  EXPIRED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String
  emailVerifiedAt   DateTime?
  dateOfBirth       DateTime
  ageVerifiedAt     DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  status            UserStatus @default(PENDING_VERIFICATION)
  adminRole         AdminRole?
  lastSeenAt        DateTime?
  riskScore         Int        @default(0)
  nif               String?    // NIF/contribuinte — account level, private
  accountName       String?    // Real name — private, different from displayName
  avatarPath        String?    // Account avatar URL
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  profile              Profile?
  consents             UserConsent[]
  subscription         Subscription?
  verification         Verification?
  blockedContacts      BlockedContactHash[]
  reportsMade          Report[]              @relation("ReporterUser")
  reportsReceived      Report[]              @relation("ReportedUser")
  messages             Message[]
  coupleApprovals      CoupleMatchApproval[]
  profileMemberships   ProfileMember[]
  referralCode         ReferralCode?
  referredAs           ReferralConversion? @relation("ReferredUserConversion")
  privateRoomMembers   PrivateRoomMember[]
  roomMessages         RoomMessage[]       @relation("RoomMessageSender")
  adminActionsPerformed AdminAction[]        @relation("AdminPerformer")
  adminActionsReceived  AdminAction[]        @relation("AdminTarget")
  betaInvites          BetaInvite[]         @relation("InviteCreator")
  betaInviteUsed       BetaInvite?          @relation("InviteUser")
  onboardingProgress   OnboardingProgress?

  @@map("users")
}

model Profile {
  id                 String        @id @default(uuid())
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               ProfileType   @default(INDIVIDUAL)
  status             ProfileStatus @default(PENDING_REVIEW)
  displayName        String
  bio                String?
  gender             String?
  orientation        String?
  relationshipStatus RelationshipStatus @default(SINGLE)
  locationLat        Float?
  locationLng        Float?
  city               String?
  country            String?
  visibilityMode     ProfileVisibility @default(PUBLIC)
  discretionLevel    DiscretionLevel   @default(SELECTIVE)
  betweenScore       Int?
  rejectionReason    String?
  moderationNotes    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  sharedDescription String?         // used by COUPLE/GROUP profiles — replaces coupleProfile.coupleDescription going forward
  coupleProfile    CoupleProfile?
  members          ProfileMember[]
  photos           ProfilePhoto[]
  intentions       ProfileIntention[]
  boundaries       ProfileBoundary[]
  privateInterests ProfilePrivateInterest[]
  privacySettings  PrivacySettings?
  actionsGiven     ProfileAction[]   @relation("ActionActor")
  actionsReceived  ProfileAction[]   @relation("ActionTarget")
  matchesAsOne     Match[]           @relation("MatchProfileOne")
  matchesAsTwo     Match[]           @relation("MatchProfileTwo")
  travelModes      TravelMode[]
  safetyCheckins   SafetyCheckin[]
  consentChecks    ConsentCheck[]

  @@map("profiles")
}

model CoupleProfile {
  id                    String       @id @default(uuid())
  profileId             String       @unique
  profile               Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  partnerOneUserId      String
  partnerTwoUserId      String?
  partnerTwoInviteEmail String?
  partnerTwoAcceptedAt  DateTime?
  coupleStatus          CoupleStatus @default(PENDING_PARTNER)
  coupleInviteToken     String?      @unique
  coupleDescription     String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("couple_profiles")
}

// Generalizes CoupleProfile's fixed partnerOne/partnerTwo pair to support
// any number of members — needed for GROUP profiles (trio, poly, etc).
// CoupleProfile stays in place for existing couple data; new group creation
// and eventually couple creation should write here instead.
model ProfileMember {
  id           String              @id @default(uuid())
  profileId    String
  profile      Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedEmail String?
  isCreator    Boolean             @default(false)
  status       ProfileMemberStatus @default(PENDING)
  inviteToken  String?             @unique
  invitedAt    DateTime            @default(now())
  respondedAt  DateTime?

  @@unique([profileId, userId])
  @@map("profile_members")
}

// 4.10 — lets the Create Profile wizard survive a refresh/tab-close
// without losing progress. Deliberately ONE per-user draft row holding a
// JSON blob, not a normalized table per field: this is throwaway scratch
// data that gets superseded the moment the real Profile is created, not
// something any other part of the app needs to query or join against.
// The wizard itself still lives entirely in CreateProfilePage.jsx as a
// single "collect everything, then POST /profiles once" flow — this only
// adds save/resume on top of that, not a step-by-step backend-driven flow
// (the /onboarding/step and /onboarding/steps routes below predate the
// current wizard, are not called by any frontend code, and are left as-is
// rather than removed or repurposed in this sprint).
model OnboardingProgress {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  step      Int      @default(1)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_progress")
}

model ProfilePhoto {
  id               String           @id @default(uuid())
  profileId        String
  profile          Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  storagePath      String
  blurredPath      String?
  visibilityLevel  PhotoVisibility  @default(BLURRED)
  moderationStatus ModerationStatus @default(PENDING)
  moderationNotes  String?
  isPrimary        Boolean          @default(false)
  sortOrder        Int              @default(0)
  exifStripped     Boolean          @default(false)
  createdAt        DateTime         @default(now())

  accessRequests   PhotoAccessRequest[]

  @@map("profile_photos")
}

model Intention {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String?
  category    String?            // Sprint 2.5.7 — optional grouping for admin catalog UI
  sensitive   Boolean            @default(false) // 4.6 — mirrors Boundary.sensitive; not shown as bluntly in UI copy
  // 4.6 — some intentions are two sides of the same interaction across
  // profile types (a couple's "seek a third person" and an individual's
  // "open to couples seeking me" are the same real-world thing from two
  // perspectives). Points at the OTHER intention's slug, not a hard FK —
  // this is compatibility metadata for IntentionCompatibilityService, not
  // a structural relationship the rest of the schema needs to enforce.
  complementarySlug String?
  sortOrder   Int                @default(0)
  active      Boolean            @default(true)
  profiles    ProfileIntention[]

  @@map("intentions")
}

model ProfileIntention {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  intentionId String
  intention   Intention @relation(fields: [intentionId], references: [id])
  preference  BoundaryPreference @default(YES)

  @@unique([profileId, intentionId])
  @@map("profile_intentions")
}

// 4.7 — before this, isHardBoundary was a blanket rule: any hard boundary
// where A=NO/B=YES excluded the pair, applied identically to every hard
// boundary regardless of what it actually means. That's fine for
// "no_couples" (a genuine mutual-alignment conflict) but wrong for
// something like a hypothetical "show my face before match" boundary,
// which is the profile's OWN visibility preference, not a claim about
// what the other person must be OK with — it should never exclude anyone.
// ruleType lets BoundaryCompatibilityService tell those apart.
enum BoundaryRuleType {
  MUTUAL_ALIGNMENT          // A and B must not directly contradict (A=NO + B=YES on the same slug, either direction)
  REQUIRE_TARGET_ACCEPTANCE // A's YES only "counts" if B hasn't explicitly said NO; B being neutral (unset/MAYBE) is not a block
  PERSONAL_PREFERENCE       // informational about the profile itself — never excludes anyone
}

model Boundary {
  id             String            @id @default(uuid())
  name           String
  slug           String            @unique
  category       String
  description    String?
  isHardBoundary Boolean           @default(false) // Sprint 2.5.8 — hard conflicts should exclude from discovery
  // 4.7 — only meaningful when isHardBoundary=true. Defaults to
  // MUTUAL_ALIGNMENT (the only behavior that existed before this field),
  // so any existing or future hard boundary that doesn't explicitly set
  // this keeps behaving exactly as before rather than silently losing its
  // exclusion power.
  ruleType       BoundaryRuleType  @default(MUTUAL_ALIGNMENT)
  sensitive      Boolean           @default(false) // Sprint 2.5.8 — not exposed directly in UI
  sortOrder      Int               @default(0)
  active         Boolean           @default(true)
  profiles       ProfileBoundary[]

  @@map("boundaries")
}

model ProfileBoundary {
  id         String             @id @default(uuid())
  profileId  String
  profile    Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  boundaryId String
  boundary   Boundary           @relation(fields: [boundaryId], references: [id])
  preference BoundaryPreference

  @@unique([profileId, boundaryId])
  @@map("profile_boundaries")
}

// 4.8 — Private Interests ("fetiches privados"). Deliberately a SEPARATE
// model from Intention/Boundary, not another category within them: these
// selections must never be shown publicly in detail, only ever as an
// aggregate count ("4 private interests aligned"), and only after some
// future explicit-consent reveal flow — nothing here should make it easy
// to accidentally expose which specific interests someone selected.
model PrivateInterest {
  id          String                   @id @default(uuid())
  slug        String                   @unique
  label       String
  category    String?
  description String?
  active      Boolean                  @default(true)
  sortOrder   Int                      @default(0)
  profiles    ProfilePrivateInterest[]

  @@map("private_interests")
}

model ProfilePrivateInterest {
  id         String             @id @default(uuid())
  profileId  String
  profile    Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  interestId String
  interest   PrivateInterest    @relation(fields: [interestId], references: [id])
  preference BoundaryPreference // reuses YES/MAYBE/NO — same shape as ProfileBoundary, no need for a fourth preference enum

  @@unique([profileId, interestId])
  @@map("profile_private_interests")
}

model PrivacySettings {
  id                 String           @id @default(uuid())
  profileId          String           @unique
  profile            Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  visibleInDiscovery Boolean          @default(true)
  showDistance       Boolean          @default(true)
  showOnlineStatus   Boolean          @default(false)
  allowPhotoRequests Boolean          @default(true)
  invisibleMode      Boolean          @default(false)
  notificationMode   NotificationMode @default(DISCREET)
  minDistanceKm      Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("privacy_settings")
}

model ProfileAction {
  id              String     @id @default(uuid())
  actorProfileId  String
  actor           Profile    @relation("ActionActor", fields: [actorProfileId], references: [id], onDelete: Cascade)
  targetProfileId String
  target          Profile    @relation("ActionTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)
  action          ActionType
  createdAt       DateTime   @default(now())

  @@unique([actorProfileId, targetProfileId])
  @@map("profile_actions")
}

model Match {
  id           String      @id @default(uuid())
  profileOneId String
  profileOne   Profile     @relation("MatchProfileOne", fields: [profileOneId], references: [id], onDelete: Cascade)
  profileTwoId String
  profileTwo   Profile     @relation("MatchProfileTwo", fields: [profileTwoId], references: [id], onDelete: Cascade)
  status       MatchStatus @default(PENDING)
  matchedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  approvals    CoupleMatchApproval[]
  conversation Conversation?
  privateRoom  PrivateRoom?
  consentChecks ConsentCheck[]

  @@unique([profileOneId, profileTwoId])
  @@map("matches")
}

model CoupleMatchApproval {
  id         String    @id @default(uuid())
  matchId    String
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([matchId, userId])
  @@map("couple_match_approvals")
}

model Conversation {
  id        String           @id @default(uuid())
  matchId   String           @unique
  match     Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      ConversationType @default(ONE_TO_ONE)
  agreedRules String[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  sender         User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body           String?
  messageType    MessageType  @default(TEXT)
  expiresAt      DateTime?
  readAt         DateTime?
  deletedAt      DateTime?
  removedByAdmin Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model PrivateRoom {
  id          String              @id @default(uuid())
  matchId     String?             @unique   // optional — rooms can exist without a match
  match       Match?              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  title       String?
  roomType    String              @default("CUSTOM")
  description String?
  rules       String[]
  status      String              @default("ACTIVE")
  createdAt   DateTime            @default(now())
  members     PrivateRoomMember[]
  messages    RoomMessage[]

  @@map("private_rooms")
}

model RoomMessage {
  id          String      @id @default(uuid())
  roomId      String
  room        PrivateRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderUserId String
  sender      User        @relation("RoomMessageSender", fields: [senderUserId], references: [id])
  body        String
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?

  @@map("room_messages")
}

model PrivateRoomMember {
  id            String      @id @default(uuid())
  privateRoomId String
  privateRoom   PrivateRoom @relation(fields: [privateRoomId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String      @default("member")
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?

  @@unique([privateRoomId, userId])
  @@map("private_room_members")
}

model ConsentCheck {
  id          String             @id @default(uuid())
  matchId     String
  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  phase       ConsentCheckPhase
  status      ConsentCheckStatus @default(PENDING)
  initiatedBy String
  respondedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())

  @@map("consent_checks")
}

model SafetyCheckin {
  id              String    @id @default(uuid())
  profileId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matchId         String?
  scheduledAt     DateTime
  safetyEmail     String?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  alertSent       Boolean   @default(false)
  locationHint    String?
  createdAt       DateTime  @default(now())

  @@map("safety_checkins")
}

model Report {
  id                String       @id @default(uuid())
  reporterUserId    String
  reporter          User         @relation("ReporterUser", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUserId    String?
  reportedUser      User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reportedMessageId String?
  reason            ReportReason
  details           String?
  status            ReportStatus @default(PENDING)
  priority          Int          @default(0)
  internalNotes     String?
  createdAt         DateTime     @default(now())
  reviewedAt        DateTime?

  @@map("reports")
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider               String             @default("stripe")
  providerCustomerId     String?
  providerSubscriptionId String?
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("subscriptions")
}

model Verification {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               VerificationType   @default(SELFIE)
  status             VerificationStatus @default(PENDING)
  provider           String?
  selfieStoragePath  String?            // URL of the selfie in R2 — deleted after review
  reviewedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())

  @@map("verifications")
}

model UserConsent {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType ConsentType
  version     String
  acceptedAt  DateTime    @default(now())
  revokedAt   DateTime?
  // T4: RGPD audit trail — required for accountability
  ipAddress   String?
  userAgent   String?

  @@map("user_consents")
}

// 3.3 — source of truth for what "version" in UserConsent.version actually
// refers to. Before this, version was a free string (hardcoded "1.0" at
// registration) with nothing behind it — no way to know what changed
// between versions, and no way to trigger reacceptance when the text
// changes. Content lives here now (LegalPage.jsx fetches it, falling back
// to its previous hardcoded copy if the API is unreachable).
model LegalDocument {
  id                   String      @id @default(uuid())
  consentType          ConsentType
  version              String
  title                String
  content              String
  publishedAt          DateTime    @default(now())
  requiresReacceptance Boolean     @default(true)
  createdAt            DateTime    @default(now())

  @@unique([consentType, version])
  @@map("legal_documents")
}

model BlockedContactHash {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactHash String
  type        String
  // 3.5 — which HMAC secret produced this hash. Rotating
  // CONTACT_HASH_SECRET orphans every hash computed under the old key
  // (HMAC is one-way — there's no way to "re-encrypt" without the original
  // plaintext, which we never store on purpose). keyVersion lets
  // ContactHashService know which secret to use when re-verifying an old
  // row, and lets admins see migration progress after a rotation.
  keyVersion  Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([userId, contactHash])
  @@map("blocked_contact_hashes")
}

model TravelMode {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  city      String
  country   String?
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("travel_modes")
}

model AdminAction {
  id          String    @id @default(uuid())
  adminId     String
  admin       User      @relation("AdminPerformer", fields: [adminId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("AdminTarget", fields: [targetUserId], references: [id])
  targetType  String
  targetId    String
  action      String
  reason      String?
  internalNote String?
  previousData Json?
  newData      Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("admin_actions")
}

model BetaInvite {
  id          String    @id @default(uuid())
  code        String    @unique
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
  usedById    String?   @unique
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id])
  email       String?
  maxUses     Int       @default(1)
  useCount    Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  @@map("beta_invites")
}

model PhotoAccessRequest {
  id           String             @id @default(uuid())
  photoId      String
  photo        ProfilePhoto       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  requesterId  String
  ownerId      String
  status       PhotoAccessStatus  @default(PENDING)
  expiresAt    DateTime?
  respondedAt  DateTime?
  createdAt    DateTime           @default(now())

  @@unique([photoId, requesterId])
  @@map("photo_access_requests")
}

// ─── Notifications ────────────────────────────────────────────────────────────
model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ─── Service Sessions (Moderator / Support shift tracking) ────────────────────
model ServiceSession {
  id          String    @id @default(uuid())
  userId      String
  role        String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationMin Int?
  notes       String?
  createdAt   DateTime  @default(now())

  @@map("service_sessions")
}

// ─── Guide Articles (Between Guide) ──────────────────────────────────────────
// ─── Referrals / Affiliate system ─────────────────────────────────────────────
model ReferralCode {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String   @unique
  createdAt   DateTime @default(now())

  conversions ReferralConversion[]

  @@map("referral_codes")
}

model ReferralConversion {
  id             String       @id @default(uuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredUserId String       @unique
  referredUser   User         @relation("ReferredUserConversion", fields: [referredUserId], references: [id], onDelete: Cascade)
  subscribedAt   DateTime?
  creditGranted  Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("referral_conversions")
}

// Singleton-style config row — editable in admin, never hardcoded in code.
model ReferralRule {
  id                String   @id @default(uuid())
  referralsRequired Int      @default(2)
  rewardMonths      Int      @default(2)
  updatedAt         DateTime @updatedAt
  updatedByUserId   String?

  @@map("referral_rules")
}

// ─── Gender catalog (Sprint 2.5.6) ────────────────────────────────────────────
// Profile.gender stays a free String (not a FK) to avoid a hard migration risk
// on existing data/custom values already stored — this is the admin-managed
// catalog of *suggested* options; the slug is what gets stored in Profile.gender.
model GenderOption {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String
  description String?
  localeKey   String?  // 4.3 — optional i18n key, for when client copy moves off hardcoded PT labels
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gender_options")
}

// 4.4 — same shape as GenderOption. orientation on Profile had zero UI to
// set it (state existed in the create/edit forms, but no <select> ever
// rendered it) — this plus the client wiring closes that gap.
model OrientationOption {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String
  description String?
  localeKey   String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("orientation_options")
}

model GuideArticle {
  id        String   @id @default(uuid())
  title     String
  category  String
  summary   String?
  body      String   @db.Text
  icon      String?  @default("○")
  published Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guide_articles")
}

// ─── Push Subscriptions (Web Push / PWA) ─────────────────────────────────────
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

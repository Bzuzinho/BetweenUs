// Between Us — Prisma Schema v4
// Roles reais + AdminAction completo + ConsentCheck + novas features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  BANNED
  DELETED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
  FINANCE
  CONTENT_REVIEWER
}

enum ProfileType {
  INDIVIDUAL
  COUPLE
  GROUP
}

enum ProfileMemberStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  HIDDEN
  SUSPENDED
}

// 4.5 — Sprint 4 evaluated migrating this to a data-driven catalog table
// (like Gender/Orientation/Intention/Boundary) and decided AGAINST it for
// now:
//   - Unlike gender/orientation, relationship status genuinely drives
//     behavior today (discovery.ts calcScore's compatMap keys off these
//     exact enum values). A data-driven catalog would need that
//     compatibility matrix to also become data-driven to avoid the
//     classic trap of "admin renames a row, matching logic silently
//     breaks" — a bigger change than a label-editing catalog.
//   - The spec's own caution applies directly: "não introduzir
//     complexidade sem impacto claro no produto." Admin being able to
//     edit a label/description/sortOrder here has real but modest value;
//     it doesn't yet justify decoupling the compatibility logic from the
//     enum.
// Also evaluated adding OPEN_RELATIONSHIP, HIERARCHICAL_POLY,
// NON_HIERARCHICAL_POLY, SOLO_POLY as new values. Not added: OPEN already
// exists and overlaps OPEN_RELATIONSHIP conceptually, and the poly
// variants are a "relationship model" distinction (how poly, structurally)
// layered on top of "relationship status" (single/committed/married/etc)
// — conflating the two into one flat enum is exactly what the spec asks
// to avoid ("separar relationship status de relationship model"). The
// clean way to add poly-structure detail is a SEPARATE field/catalog, not
// more enum values here — deferred until there's a concrete product need
// for it, per the same anti-complexity caution above.
enum RelationshipStatus {
  SINGLE
  COMMITTED
  MARRIED
  OPEN
  POLYAMOROUS
  COUPLE_CURIOUS
  COUPLE_LIBERAL
  OTHER
}

enum DiscretionLevel {
  MAXIMUM
  SELECTIVE
  OPEN
}

enum ProfileVisibility {
  PUBLIC
  MATCHES_ONLY
  INVISIBLE
}

enum PhotoVisibility {
  PUBLIC
  BLURRED
  PRIVATE_AFTER_MATCH
  PRIVATE_AFTER_APPROVAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum BoundaryPreference {
  YES
  MAYBE
  NO
}

enum ActionType {
  LIKE
  PASS
  SUPER_LIKE
  BLOCK
  REPORT
}

enum MatchStatus {
  PENDING
  PENDING_COUPLE_APPROVAL
  ACTIVE
  PAUSED
  ENDED
  BLOCKED
}

enum CoupleStatus {
  PENDING_PARTNER
  ACTIVE
  PAUSED
  SEPARATED
  DISABLED
}

// 6.5 — formalizes "who must approve a match" as an explicit policy rather
// than the implicit "every ACCEPTED member" behavior
// ProfileMembershipService.getRequiredApprovers already had. COUPLE always
// behaves as ALL (enforced in code, not by this field being immutable -
// see approvalPolicyService.ts's comment on why). MAJORITY/DESIGNATED exist
// for GROUP's future use ("feature futura" per the spec) - not implemented
// as real alternate behavior yet.
enum ApprovalPolicy {
  ALL
  MAJORITY
  DESIGNATED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
  CONSENT_REQUEST
  PHOTO_UNLOCK_REQUEST
  // 7.6 — added for RoomMessage's richer message vocabulary. Also valid on
  // Conversation's Message (shared enum) though no current code path there
  // produces them.
  RULE_UPDATE
  SAFETY
}

enum ConversationType {
  ONE_TO_ONE
  COUPLE_GROUP
  PRIVATE_ROOM
}

enum ReportReason {
  FAKE_PROFILE
  HARASSMENT
  OFFENSIVE_CONTENT
  MINOR
  NON_CONSENSUAL_IMAGE
  SPAM
  THREAT
  COERCION
  REVENGE_PORN
  DOXXING
  PROSTITUTION_OR_ESCORT
  PAID_SEXUAL_SERVICES
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
  ESCALATED
}

// 9.1 — evidence captured at report-submission time, deliberately
// snapshotted rather than referencing live rows: a MESSAGE_SNAPSHOT must
// stay readable to moderation even if the underlying Message/RoomMessage
// is later soft-deleted (by the sender, by TTL expiry, or by the cleanup
// job) or the sender's account is altered. `data` is a restricted subset
// of fields (see reportEvidenceService.ts), never a full dump of
// unrelated content.
enum EvidenceType {
  MESSAGE_SNAPSHOT
  PROFILE_SNAPSHOT
  MEDIA_REFERENCE
  ROOM_CONTEXT
  SYSTEM_EVENT
}

// 9.5 — replaces the ad-hoc toStatus() derivation (alertSent/cancelledAt/
// confirmedAt booleans with no formal notion of "in between" states) with
// an explicit, service-written status. Old boolean fields stay for
// read-compat with anything already querying them directly.
enum SafetyCheckinStatus {
  SCHEDULED
  WAITING_CONFIRMATION
  SAFE_CONFIRMED
  OVERDUE
  ESCALATED
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  COUPLE_PREMIUM
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIALING
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// 3.4 — was a free-form String defaulting to "selfie"; no taxonomy, no
// public badge exposure. Kept 1-per-user cardinality (Verification.userId
// stays @unique) to avoid destabilizing UserActivationService/
// EligibilityService, both built in Sprint 2.5 around a single verification
// record per user. True multi-type verification (tracking SELFIE and
// ID_DOCUMENT simultaneously for one user) would need Verification.userId
// to become non-unique + those two services updated accordingly — flagged
// as follow-up, out of proportion to what this sprint asked for.
enum VerificationType {
  SELFIE
  ID_DOCUMENT
  VIDEO
}

enum ConsentType {
  TERMS
  PRIVACY_POLICY
  SENSITIVE_DATA
  MARKETING
  LOCATION
  CONTACT_HASHING
}

enum NotificationMode {
  NORMAL
  DISCREET
  SILENT
}

// 8.3 — ConsentCheck.status stays a CACHED aggregate, recomputed by
// consentCheckService from ConsentCheckResponse rows. It is never written
// directly from a route in response to one person's answer — see 8.2/8.3.
enum ConsentCheckStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ConsentCheckPhase {
  MATCH
  CHAT
  PHOTO_REQUEST
  FACE_REVEAL
  VIDEO_CALL
  MEETING_PROPOSAL
  SAFETY_CHECKIN
}

// 8.2 — per-responder answer to a ConsentCheck. NOT_YET is an explicit,
// distinct answer ("not ready yet") — it must never be treated as
// ACCEPTED, and it is distinct from PENDING (no answer at all/silence).
// REVOKED is only reachable from ACCEPTED (see consentCheckService).
enum ConsentResponseStatus {
  PENDING
  ACCEPTED
  NOT_YET
  DECLINED
  REVOKED
}

// 8.10 — mirrors RoomRuleSet's DRAFT/ACTIVE/SUPERSEDED-style version
// lifecycle: at most one ACTIVE IntentAlignment per room at a time.
enum IntentAlignmentStatus {
  DRAFT
  WAITING_APPROVAL
  ACTIVE
  ARCHIVED
}

enum PhotoAccessStatus {
  PENDING
  APPROVED
  DECLINED
  REVOKED
  EXPIRED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String
  emailVerifiedAt   DateTime?
  dateOfBirth       DateTime
  ageVerifiedAt     DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  status            UserStatus @default(PENDING_VERIFICATION)
  adminRole         AdminRole?
  lastSeenAt        DateTime?
  riskScore         Int        @default(0)
  nif               String?    // NIF/contribuinte — account level, private
  accountName       String?    // Real name — private, different from displayName
  avatarPath        String?    // Account avatar URL
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  profile              Profile?
  consents             UserConsent[]
  subscription         Subscription?
  verification         Verification?
  blockedContacts      BlockedContactHash[]
  reportsMade          Report[]              @relation("ReporterUser")
  reportsReceived      Report[]              @relation("ReportedUser")
  messages             Message[]
  coupleApprovals      CoupleMatchApproval[]
  profileMemberships   ProfileMember[]
  referralCode         ReferralCode?
  referredAs           ReferralConversion? @relation("ReferredUserConversion")
  privateRoomMembers   PrivateRoomMember[]
  roomMessages         RoomMessage[]       @relation("RoomMessageSender")
  adminActionsPerformed AdminAction[]        @relation("AdminPerformer")
  adminActionsReceived  AdminAction[]        @relation("AdminTarget")
  betaInvites          BetaInvite[]         @relation("InviteCreator")
  betaInviteUsed       BetaInvite?          @relation("InviteUser")
  onboardingProgress   OnboardingProgress?
  travelModeApprovals  TravelModeApproval[]
  photoAccessApprovals PhotoAccessApproval[]
  roomRuleApprovals    RoomRuleApproval[]
  consentCheckResponses ConsentCheckResponse[]
  intentAlignmentApprovals IntentAlignmentApproval[]

  // 5.11 — discovery's candidate query joins on user.status (and
  // effectively adminRole via a null check) for every request.
  @@index([status])
  @@map("users")
}

model Profile {
  id                 String        @id @default(uuid())
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               ProfileType   @default(INDIVIDUAL)
  status             ProfileStatus @default(PENDING_REVIEW)
  displayName        String
  bio                String?
  gender             String?
  orientation        String?
  relationshipStatus RelationshipStatus @default(SINGLE)
  locationLat        Float?
  locationLng        Float?
  city               String?
  country            String?
  visibilityMode     ProfileVisibility @default(PUBLIC)
  discretionLevel    DiscretionLevel   @default(SELECTIVE)
  betweenScore       Int?
  rejectionReason    String?
  moderationNotes    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  sharedDescription String?         // used by COUPLE/GROUP profiles — replaces coupleProfile.coupleDescription going forward
  coupleProfile    CoupleProfile?
  members          ProfileMember[]
  photos           ProfilePhoto[]
  intentions       ProfileIntention[]
  boundaries       ProfileBoundary[]
  privateInterests ProfilePrivateInterest[]
  privacySettings  PrivacySettings?
  actionsGiven     ProfileAction[]   @relation("ActionActor")
  actionsReceived  ProfileAction[]   @relation("ActionTarget")
  matchesAsOne     Match[]           @relation("MatchProfileOne")
  matchesAsTwo     Match[]           @relation("MatchProfileTwo")
  travelModes      TravelMode[]
  safetyCheckins   SafetyCheckin[]
  compatibilityScoresAsSource CompatibilityScore[] @relation("CompatibilityScoreSource")
  compatibilityScoresAsTarget CompatibilityScore[] @relation("CompatibilityScoreTarget")

  agreements ProfileAgreement[]

  // 6.5 — ApprovalPolicy formalizes what was already implicit behavior:
  // ProfileMembershipService.getRequiredApprovers already returns every
  // ACCEPTED member, which IS "ALL" - this makes that explicit and gives
  // GROUP a place to diverge later without touching COUPLE's semantics.
  // COUPLE ignores this field and always behaves as ALL (see
  // approvalPolicyService.ts) - stored mainly for GROUP's future use and
  // for admin visibility (6.10).
  approvalPolicy ApprovalPolicy @default(ALL)

  // 5.11 — discovery's candidate-pool query filters on status+type together
  // on every request; before this there was no index on either column at
  // all, meaning a full table scan of profiles for every single discovery
  // request regardless of profile count.
  @@index([status, type])
  @@map("profiles")
}

model CoupleProfile {
  id                    String       @id @default(uuid())
  profileId             String       @unique
  profile               Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  partnerOneUserId      String
  partnerTwoUserId      String?
  partnerTwoInviteEmail String?
  partnerTwoAcceptedAt  DateTime?
  coupleStatus          CoupleStatus @default(PENDING_PARTNER)
  coupleInviteToken     String?      @unique
  coupleDescription     String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("couple_profiles")
}

// Generalizes CoupleProfile's fixed partnerOne/partnerTwo pair to support
// any number of members — needed for GROUP profiles (trio, poly, etc).
// CoupleProfile stays in place for existing couple data; new group creation
// and eventually couple creation should write here instead.
model ProfileMember {
  id           String              @id @default(uuid())
  profileId    String
  profile      Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedEmail String?
  isCreator    Boolean             @default(false)
  status       ProfileMemberStatus @default(PENDING)
  inviteToken  String?             @unique
  invitedAt    DateTime            @default(now())
  respondedAt  DateTime?

  agreementAnswers ProfileAgreementAnswer[]

  @@unique([profileId, userId])
  @@map("profile_members")
}

// 4.10 — lets the Create Profile wizard survive a refresh/tab-close
// without losing progress. Deliberately ONE per-user draft row holding a
// JSON blob, not a normalized table per field: this is throwaway scratch
// data that gets superseded the moment the real Profile is created, not
// something any other part of the app needs to query or join against.
// The wizard itself still lives entirely in CreateProfilePage.jsx as a
// single "collect everything, then POST /profiles once" flow — this only
// adds save/resume on top of that, not a step-by-step backend-driven flow
// (the /onboarding/step and /onboarding/steps routes below predate the
// current wizard, are not called by any frontend code, and are left as-is
// rather than removed or repurposed in this sprint).
model OnboardingProgress {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  step      Int      @default(1)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_progress")
}

// 6.8 — memberScope/depictedMemberIds are new. Deliberately manual, set by
// the uploader at upload time (or edited after) — never facial recognition
// or any automated detection, per the spec's explicit instruction.
// depictedMemberIds holds ProfileMember ids, not User ids, consistent with
// ProfileMembershipService being the membership source of truth everywhere
// else in this codebase.
enum MediaMemberScope {
  SINGLE_MEMBER     // depicts only the uploader — default, matches all pre-Sprint-6 photos
  MULTIPLE_MEMBERS  // depicts 2+ specific, identified members of a COUPLE/GROUP profile
  SHARED_PROFILE    // couple/group photo not clearly of specific individuals (e.g. a joint photo, a symbol/object) — still requires all active members' consent to grant, same as MULTIPLE_MEMBERS
}

model ProfilePhoto {
  id               String           @id @default(uuid())
  profileId        String
  profile          Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  storagePath      String
  blurredPath      String?
  visibilityLevel  PhotoVisibility  @default(BLURRED)
  moderationStatus ModerationStatus @default(PENDING)
  moderationNotes  String?
  isPrimary        Boolean          @default(false)
  sortOrder        Int              @default(0)
  exifStripped     Boolean          @default(false)
  memberScope      MediaMemberScope @default(SINGLE_MEMBER)
  depictedMemberIds String[]        @default([])
  createdAt        DateTime         @default(now())

  accessRequests   PhotoAccessRequest[]

  @@map("profile_photos")
}

model Intention {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String?
  category    String?            // Sprint 2.5.7 — optional grouping for admin catalog UI
  sensitive   Boolean            @default(false) // 4.6 — mirrors Boundary.sensitive; not shown as bluntly in UI copy
  // 4.6 — some intentions are two sides of the same interaction across
  // profile types (a couple's "seek a third person" and an individual's
  // "open to couples seeking me" are the same real-world thing from two
  // perspectives). Points at the OTHER intention's slug, not a hard FK —
  // this is compatibility metadata for IntentionCompatibilityService, not
  // a structural relationship the rest of the schema needs to enforce.
  complementarySlug String?
  sortOrder   Int                @default(0)
  active      Boolean            @default(true)
  profiles    ProfileIntention[]

  @@map("intentions")
}

model ProfileIntention {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  intentionId String
  intention   Intention @relation(fields: [intentionId], references: [id])
  preference  BoundaryPreference @default(YES)

  @@unique([profileId, intentionId])
  @@map("profile_intentions")
}

// 4.7 — before this, isHardBoundary was a blanket rule: any hard boundary
// where A=NO/B=YES excluded the pair, applied identically to every hard
// boundary regardless of what it actually means. That's fine for
// "no_couples" (a genuine mutual-alignment conflict) but wrong for
// something like a hypothetical "show my face before match" boundary,
// which is the profile's OWN visibility preference, not a claim about
// what the other person must be OK with — it should never exclude anyone.
// ruleType lets BoundaryCompatibilityService tell those apart.
enum BoundaryRuleType {
  MUTUAL_ALIGNMENT          // A and B must not directly contradict (A=NO + B=YES on the same slug, either direction)
  REQUIRE_TARGET_ACCEPTANCE // A's YES only "counts" if B hasn't explicitly said NO; B being neutral (unset/MAYBE) is not a block
  PERSONAL_PREFERENCE       // informational about the profile itself — never excludes anyone
}

model Boundary {
  id             String            @id @default(uuid())
  name           String
  slug           String            @unique
  category       String
  description    String?
  isHardBoundary Boolean           @default(false) // Sprint 2.5.8 — hard conflicts should exclude from discovery
  // 4.7 — only meaningful when isHardBoundary=true. Defaults to
  // MUTUAL_ALIGNMENT (the only behavior that existed before this field),
  // so any existing or future hard boundary that doesn't explicitly set
  // this keeps behaving exactly as before rather than silently losing its
  // exclusion power.
  ruleType       BoundaryRuleType  @default(MUTUAL_ALIGNMENT)
  sensitive      Boolean           @default(false) // Sprint 2.5.8 — not exposed directly in UI
  sortOrder      Int               @default(0)
  active         Boolean           @default(true)
  profiles       ProfileBoundary[]
  agreementAnswers ProfileAgreementAnswer[]

  @@map("boundaries")
}

model ProfileBoundary {
  id         String             @id @default(uuid())
  profileId  String
  profile    Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  boundaryId String
  boundary   Boundary           @relation(fields: [boundaryId], references: [id])
  preference BoundaryPreference

  @@unique([profileId, boundaryId])
  @@map("profile_boundaries")
}

// 6.1 — Modo Acordo: replaces the pre-Sprint-6 fake version (any one
// partner directly PUT-ing Profile.intentions/boundaries, no individual
// answers, no waiting for the other member, no conflict detection - see
// the Sprint 6 audit note in couples.ts) with a real per-member-answer,
// conservative-merge mechanic.
//
// One ProfileAgreement row per "round" of the couple's shared answers -
// version increments only when a member starts a NEW round after a LOCKED
// or EXPIRED one, not on every individual answer (those just update
// ProfileAgreementAnswer rows within the current version).
enum ProfileAgreementStatus {
  DRAFT             // created, no member has answered anything yet
  WAITING_MEMBERS   // at least one member has answered, not all have
  ALIGNED           // all active members answered every question, no conflicts
  CONFLICT          // all active members answered, at least one real disagreement
  LOCKED            // explicitly locked (e.g. required before certain actions) - answers frozen
  EXPIRED           // past expiresAt - membership changed or admin/product policy invalidated it
}

model ProfileAgreement {
  id        String                 @id @default(uuid())
  profileId String
  profile   Profile                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  version   Int                    @default(1)
  status    ProfileAgreementStatus @default(DRAFT)
  lockedAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  answers   ProfileAgreementAnswer[]

  @@unique([profileId, version])
  @@map("profile_agreements")
}

// Exactly one of boundaryId / agreementQuestionId is set, never both, never
// neither - enforced in ProfileAgreementService, not at the DB level
// (Postgres unique constraints don't reliably dedupe across nullable
// columns anyway, so uniqueness-per-member-per-question is also handled in
// the service via find-then-upsert, same pattern ProfileBoundary/
// ProfileIntention already use elsewhere in this schema).
model ProfileAgreementAnswer {
  id                  String             @id @default(uuid())
  agreementId         String
  agreement           ProfileAgreement   @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  profileMemberId     String
  profileMember       ProfileMember      @relation(fields: [profileMemberId], references: [id], onDelete: Cascade)
  boundaryId          String?
  boundary            Boundary?          @relation(fields: [boundaryId], references: [id])
  agreementQuestionId String?
  agreementQuestion   AgreementQuestion? @relation(fields: [agreementQuestionId], references: [id])
  preference          BoundaryPreference
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([agreementId, profileMemberId])
  @@map("profile_agreement_answers")
}

// 6.2 — questions specific to how the COUPLE operates as a unit (their own
// internal process), not compatibility preferences compared against a
// third party's Boundary selections. BOTH_VALIDATE_MATCH is the clear
// example from the spec's own list: everything else in that list
// (NO_EMOTIONAL_INVOLVEMENT, ONE_TIME_ONLY, VERIFIED_ONLY, SINGLES_ONLY/
// COUPLES_ONLY, NO_KNOWN_PEOPLE, NO_FACE_AT_START, TALK_FIRST, etc.) already
// exists as a Boundary slug from Sprint 2.5.8's seed and is reused via
// ProfileAgreementAnswer.boundaryId instead of being duplicated here.
model AgreementQuestion {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String
  description String?
  category    String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  answers     ProfileAgreementAnswer[]

  @@map("agreement_questions")
}

// 4.8 — Private Interests ("fetiches privados"). Deliberately a SEPARATE
// model from Intention/Boundary, not another category within them: these
// selections must never be shown publicly in detail, only ever as an
// aggregate count ("4 private interests aligned"), and only after some
// future explicit-consent reveal flow — nothing here should make it easy
// to accidentally expose which specific interests someone selected.
model PrivateInterest {
  id          String                   @id @default(uuid())
  slug        String                   @unique
  label       String
  category    String?
  description String?
  active      Boolean                  @default(true)
  sortOrder   Int                      @default(0)
  profiles    ProfilePrivateInterest[]

  @@map("private_interests")
}

model ProfilePrivateInterest {
  id         String             @id @default(uuid())
  profileId  String
  profile    Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  interestId String
  interest   PrivateInterest    @relation(fields: [interestId], references: [id])
  preference BoundaryPreference // reuses YES/MAYBE/NO — same shape as ProfileBoundary, no need for a fourth preference enum

  @@unique([profileId, interestId])
  @@map("profile_private_interests")
}

model PrivacySettings {
  id                 String           @id @default(uuid())
  profileId          String           @unique
  profile            Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  visibleInDiscovery Boolean          @default(true)
  showDistance       Boolean          @default(true)
  showOnlineStatus   Boolean          @default(false)
  allowPhotoRequests Boolean          @default(true)
  invisibleMode      Boolean          @default(false)
  notificationMode   NotificationMode @default(DISCREET)
  minDistanceKm      Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("privacy_settings")
}

model ProfileAction {
  id              String     @id @default(uuid())
  actorProfileId  String
  actor           Profile    @relation("ActionActor", fields: [actorProfileId], references: [id], onDelete: Cascade)
  targetProfileId String
  target          Profile    @relation("ActionTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)
  action          ActionType
  createdAt       DateTime   @default(now())

  @@unique([actorProfileId, targetProfileId])
  // 5.11/5.3 — discovery now also needs "who has BLOCKed the viewer"
  // (reverse direction, previously never checked at all - see the 5.3
  // audit note in discoveryService.ts) and "who has LIKEd the viewer",
  // both filtered by targetProfileId + action.
  @@index([targetProfileId, action])
  @@map("profile_actions")
}

model Match {
  id           String      @id @default(uuid())
  profileOneId String
  profileOne   Profile     @relation("MatchProfileOne", fields: [profileOneId], references: [id], onDelete: Cascade)
  profileTwoId String
  profileTwo   Profile     @relation("MatchProfileTwo", fields: [profileTwoId], references: [id], onDelete: Cascade)
  status       MatchStatus @default(PENDING)
  matchedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  approvals    CoupleMatchApproval[]
  conversation Conversation?
  privateRoom  PrivateRoom?
  consentChecks ConsentCheck[]

  // 5.11 — the composite unique above gives a usable index for
  // profileOneId-only lookups (it's the leftmost column), but NOT for
  // profileTwoId-only lookups (e.g. discovery's "am I already matched with
  // this candidate" OR-clause, matches.ts's inbox query) - those need
  // their own index or they full-scan.
  @@index([profileTwoId])
  @@index([status])
  @@unique([profileOneId, profileTwoId])
  @@map("matches")
}

model CoupleMatchApproval {
  id         String    @id @default(uuid())
  matchId    String
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([matchId, userId])
  @@map("couple_match_approvals")
}

model Conversation {
  id        String           @id @default(uuid())
  matchId   String           @unique
  match     Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      ConversationType @default(ONE_TO_ONE)
  agreedRules String[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  sender         User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body           String?
  messageType    MessageType  @default(TEXT)
  expiresAt      DateTime?
  readAt         DateTime?
  deletedAt      DateTime?
  removedByAdmin Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("messages")
}

// 7.2 — replaces the old free-string roomType. INDIVIDUAL_PAIR/COUPLE_SINGLE/
// COUPLE_COUPLE/POLY_GROUP are composition-based (derived from the actual
// participants), CUSTOM is the fallback for standalone rooms created by a
// user picking a vibe/label rather than rooms derived from a match. Old
// string values (TRIO, SWING_GROUP, POLYAMORY, COUPLE_PLUS_ONE,
// COUPLE_PLUS_COUPLE) are backfilled per-row from actual membership by the
// 7.2 migration script, not a blind string map — see
// scripts/migratePrivateRoomEnums.ts.
enum PrivateRoomType {
  INDIVIDUAL_PAIR
  COUPLE_SINGLE
  COUPLE_COUPLE
  POLY_GROUP
  CUSTOM
}

// 7.3 — see PrivateRoomStateMachine for the transition table. DRAFT: just
// created, no active rule set yet. WAITING_CONSENT: a rule set version
// exists but not everyone has accepted it — new messages are blocked.
// ACTIVE: everyone has accepted the current rule set. PAUSED: manually
// paused by a member. CLOSED: terminal, room archived. SAFETY_LOCKED: an
// admin/safety action froze the room (distinct from CLOSED — reversible
// via UNLOCK, and distinct from a member-initiated PAUSE).
enum PrivateRoomStatus {
  DRAFT
  WAITING_CONSENT
  ACTIVE
  PAUSED
  CLOSED
  SAFETY_LOCKED
}

// 7.5 — OWNER: creator of a standalone room (POST /rooms); match-derived
// rooms (PrivateRoomService.createFromMatch) deliberately assign no OWNER
// — the room is peer-symmetric, no single participant should have
// unilateral control over a room born from a match between equals.
// MODERATOR_SYSTEM: reserved for a future system/admin moderation
// presence in the room; never assigned to a normal member automatically
// (explicit spec requirement — "Não dar permissões de moderação de
// conteúdo a owner normal").
enum RoomMemberRole {
  OWNER
  MEMBER
  MODERATOR_SYSTEM
}

// 7.5 — separate from role. The old code overloaded role itself with an
// 'invited' string value (no role yet, just a placeholder) which doesn't
// fit a real RoomMemberRole enum - INVITED members have no role opinion
// yet. Mirrors ProfileMember's own status/isCreator separation.
enum RoomMemberStatus {
  INVITED
  ACCEPTED
}

// 7.7 — the room-level default applied to new messages that don't specify
// their own expiresAt. Purely a convenience TTL preset, not a security
// boundary - see the cleanup job's own comment on why this must never be
// marketed as screenshot protection.
enum MessageTtlPreset {
  NONE
  ONE_HOUR
  ONE_DAY
  SEVEN_DAYS
}

// 7.4 — DRAFT: being assembled, not yet requiring consent. ACTIVE: the
// room's current live rule set (at most one per room at a time).
// SUPERSEDED: replaced by a newer version once every member re-accepts.
enum RoomRuleSetStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
}

model PrivateRoom {
  id          String              @id @default(uuid())
  matchId     String?             @unique   // optional — rooms can exist without a match
  match       Match?              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  title       String?
  roomType    PrivateRoomType     @default(CUSTOM)
  description String?
  // 7.4 — kept temporarily for read-compat with any client still rendering
  // the old flat list; RoomRuleSet/RoomRule are now the source of truth.
  // Not written to by any Sprint 7 code path.
  rules       String[]
  status      PrivateRoomStatus   @default(DRAFT)
  defaultMessageTtl MessageTtlPreset @default(NONE)
  closedAt        DateTime?
  safetyLockedAt  DateTime?
  createdAt   DateTime            @default(now())
  members     PrivateRoomMember[]
  messages    RoomMessage[]
  ruleSets    RoomRuleSet[]
  intentAlignments IntentAlignment[]

  @@map("private_rooms")
}

// 7.6 — RoomMessage V2: body is now optional (IMAGE/SYSTEM messages carry
// no text), messageType classifies the message, mediaId points at a
// private storage key (photos flow through the same signed-URL access
// pattern as ProfilePhoto — see mediaAccessService), expiresAt/readAt
// mirror Message's already-existing fields on Conversation so the same
// cleanup job can treat both uniformly.
model RoomMessage {
  id           String          @id @default(uuid())
  roomId       String
  room         PrivateRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderUserId String
  sender       User            @relation("RoomMessageSender", fields: [senderUserId], references: [id])
  body         String?
  messageType  MessageType     @default(TEXT)
  mediaId      String?
  expiresAt    DateTime?
  readAt       DateTime?
  createdAt    DateTime        @default(now())
  deletedAt    DateTime?

  @@index([roomId, createdAt])
  @@map("room_messages")
}

model PrivateRoomMember {
  id            String           @id @default(uuid())
  privateRoomId String
  privateRoom   PrivateRoom      @relation(fields: [privateRoomId], references: [id], onDelete: Cascade)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          RoomMemberRole   @default(MEMBER)
  status        RoomMemberStatus @default(ACCEPTED)
  joinedAt      DateTime         @default(now())
  leftAt        DateTime?

  @@unique([privateRoomId, userId])
  @@map("private_room_members")
}

// 7.4 — a versioned, room-wide rule set. At most one ACTIVE per room;
// creating a new version (material rule change) moves the prior ACTIVE
// set to SUPERSEDED and the room to WAITING_CONSENT until every active
// member re-accepts the new version (see roomRuleService.ts).
model RoomRuleSet {
  id              String            @id @default(uuid())
  roomId          String
  room            PrivateRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  version         Int
  status          RoomRuleSetStatus @default(DRAFT)
  createdByUserId String
  createdAt       DateTime          @default(now())
  activatedAt     DateTime?
  rules           RoomRule[]
  approvals       RoomRuleApproval[]

  @@unique([roomId, version])
  @@map("room_rule_sets")
}

// ruleType is a free-string category (same conventionally-fixed-but-not-
// enum-enforced pattern as Boundary.category) — e.g. CONSENT, PRIVACY,
// COMMUNICATION, MEETING, SAFETY — so new categories don't need a schema
// change.
model RoomRule {
  id        String      @id @default(uuid())
  ruleSetId String
  ruleSet   RoomRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  ruleType  String
  label     String
  value     String?
  sortOrder Int         @default(0)

  @@map("room_rules")
}

// One row per (ruleSet, member) who has weighed in. Keyed directly on
// userId (not profileMemberId) — PrivateRoomMember itself is already
// user-level, not profile-member-level (a couple's two members already
// show up as two separate PrivateRoomMember rows once a room is created
// from a match), so there's no extra indirection needed here.
model RoomRuleApproval {
  id         String      @id @default(uuid())
  ruleSetId  String
  ruleSet    RoomRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@unique([ruleSetId, userId])
  @@map("room_rule_approvals")
}

// 8.2 — ConsentCheck is now the REQUEST/PHASE record only ("is there an
// open ask to move to FACE_REVEAL on this match"), not a per-person state.
// Each required participant gets their own ConsentCheckResponse row (see
// below) — status here is a cached aggregate only, see ConsentCheckStatus.
// profileId was removed: a check is no longer "owned" by one side's
// profile, it applies to the whole match (per-person state lives on the
// responses instead).
model ConsentCheck {
  id          String             @id @default(uuid())
  matchId     String
  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  phase       ConsentCheckPhase
  status      ConsentCheckStatus @default(PENDING)
  initiatedBy String
  respondedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())

  responses   ConsentCheckResponse[]

  @@map("consent_checks")
}

// 8.2 — one row per required participant per ConsentCheck. This is the
// actual source of truth consentCheckService aggregates from — see the
// comment on ConsentCheck.status. respondedAt is set the moment status
// moves away from PENDING (ACCEPTED/NOT_YET/DECLINED); revokedAt is set
// only on the ACCEPTED -> REVOKED transition.
model ConsentCheckResponse {
  id             String                @id @default(uuid())
  consentCheckId String
  consentCheck   ConsentCheck          @relation(fields: [consentCheckId], references: [id], onDelete: Cascade)
  userId         String
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         ConsentResponseStatus @default(PENDING)
  respondedAt    DateTime?
  revokedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([consentCheckId, userId])
  @@map("consent_check_responses")
}

// 8.8/8.9 — "Shared Intentions" (product name) / IntentAlignment
// (technical name). Explicitly NOT a legal contract — see 8.8. Scoped to
// a PrivateRoom, structurally distinct from RoomRuleSet (in-room
// behaviour) and ConsentCheck (permission for one phase/action) — see
// 8.11: never mix these three concepts in the UI or in queries.
model IntentAlignment {
  id              String                 @id @default(uuid())
  privateRoomId   String
  privateRoom     PrivateRoom            @relation(fields: [privateRoomId], references: [id], onDelete: Cascade)
  version         Int
  status          IntentAlignmentStatus  @default(DRAFT)
  createdByUserId String
  createdAt       DateTime               @default(now())
  activatedAt     DateTime?
  archivedAt      DateTime?

  items       IntentAlignmentItem[]
  approvals   IntentAlignmentApproval[]

  @@map("intent_alignments")
}

// 8.9 — key/value/label kept generic (String) rather than a fixed struct,
// consistent with ProfileAgreementAnswer's pattern — see
// lib/intentAlignmentFields.ts for the catalog of known keys/allowed
// values/labels this sprint ships with (connection_goal,
// meeting_openness, emotional_openness, recurrence, confidentiality,
// communication_pace). Not DB-enforced so the catalog can grow without a
// migration, same tradeoff already made for AgreementQuestion answers.
model IntentAlignmentItem {
  id          String          @id @default(uuid())
  alignmentId String
  alignment   IntentAlignment @relation(fields: [alignmentId], references: [id], onDelete: Cascade)
  key         String
  value       String
  label       String?

  @@unique([alignmentId, key])
  @@map("intent_alignment_items")
}

// 8.10 — per-member approval of a DRAFT/WAITING_APPROVAL version. A
// declinedAt (rather than only approvedAt/revokedAt) lets one explicit
// "no" archive the proposal immediately without ever activating it, while
// the previous ACTIVE alignment is left completely untouched — see
// intentAlignmentService.ts.
model IntentAlignmentApproval {
  id          String          @id @default(uuid())
  alignmentId String
  alignment   IntentAlignment @relation(fields: [alignmentId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedAt  DateTime?
  declinedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime        @default(now())

  @@unique([alignmentId, userId])
  @@map("intent_alignment_approvals")
}

model SafetyCheckin {
  id              String    @id @default(uuid())
  profileId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matchId         String?
  scheduledAt     DateTime
  safetyEmail     String?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  alertSent       Boolean   @default(false)
  locationHint    String?
  createdAt       DateTime  @default(now())
  // 9.5/9.6 — explicit state machine field, written only through
  // SafetyCheckinStateMachine.transition(). requestSentAt/overdueAt/
  // escalatedAt record WHEN each job-driven transition happened, so each
  // of the three jobs (request/overdue/escalation) can query
  // "haven't done X yet" without re-deriving it from timing math each run.
  status          SafetyCheckinStatus @default(SCHEDULED)
  requestSentAt   DateTime?
  overdueAt       DateTime?
  escalatedAt     DateTime?

  @@map("safety_checkins")
}

model Report {
  id                String       @id @default(uuid())
  reporterUserId    String
  reporter          User         @relation("ReporterUser", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUserId    String?
  reportedUser      User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reportedMessageId String?
  reason            ReportReason
  details           String?
  status            ReportStatus @default(PENDING)
  priority          Int          @default(0)
  internalNotes     String?
  createdAt         DateTime     @default(now())
  reviewedAt        DateTime?

  evidence             ReportEvidence[]
  moderationAssessments ModerationAssessment[]

  @@map("reports")
}

// 9.1 — snapshotted evidence, not a live reference. `data` holds the
// restricted field subset for the given `type` (see
// reportEvidenceService.ts's SNAPSHOT builders) — e.g. for
// MESSAGE_SNAPSHOT: { messageId, body, senderUserId, sentAt, roomId }.
// Deliberately no relation to Message/RoomMessage: the whole point is
// that this keeps reading correctly after the source row is soft-deleted.
model ReportEvidence {
  id        String       @id @default(uuid())
  reportId  String
  report    Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      EvidenceType
  data      Json
  createdAt DateTime     @default(now())

  @@map("report_evidence")
}

// 9.8 — one row per assessment RUN (a report could be re-assessed after
// new evidence arrives), never mutated after creation — an audit trail of
// what the AI said and when, kept fully separate from the human decision
// (Report.status / AdminAction), per 9.11's "guardar AI recommendation;
// human decision" as two distinct, comparable records rather than one
// overwriting the other.
model ModerationAssessment {
  id           String   @id @default(uuid())
  reportId     String
  report       Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  provider     String
  model        String
  promptVersion String
  result       Json
  confidence   Float
  createdAt    DateTime @default(now())

  @@map("moderation_assessments")
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider               String             @default("stripe")
  providerCustomerId     String?
  providerSubscriptionId String?
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("subscriptions")
}

model Verification {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               VerificationType   @default(SELFIE)
  status             VerificationStatus @default(PENDING)
  provider           String?
  selfieStoragePath  String?            // URL of the selfie in R2 — deleted after review
  reviewedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())

  @@map("verifications")
}

model UserConsent {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType ConsentType
  version     String
  acceptedAt  DateTime    @default(now())
  revokedAt   DateTime?
  // T4: RGPD audit trail — required for accountability
  ipAddress   String?
  userAgent   String?

  @@map("user_consents")
}

// 3.3 — source of truth for what "version" in UserConsent.version actually
// refers to. Before this, version was a free string (hardcoded "1.0" at
// registration) with nothing behind it — no way to know what changed
// between versions, and no way to trigger reacceptance when the text
// changes. Content lives here now (LegalPage.jsx fetches it, falling back
// to its previous hardcoded copy if the API is unreachable).
model LegalDocument {
  id                   String      @id @default(uuid())
  consentType          ConsentType
  version              String
  title                String
  content              String
  publishedAt          DateTime    @default(now())
  requiresReacceptance Boolean     @default(true)
  createdAt            DateTime    @default(now())

  @@unique([consentType, version])
  @@map("legal_documents")
}

model BlockedContactHash {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactHash String
  type        String
  // 3.5 — which HMAC secret produced this hash. Rotating
  // CONTACT_HASH_SECRET orphans every hash computed under the old key
  // (HMAC is one-way — there's no way to "re-encrypt" without the original
  // plaintext, which we never store on purpose). keyVersion lets
  // ContactHashService know which secret to use when re-verifying an old
  // row, and lets admins see migration progress after a rotation.
  keyVersion  Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([userId, contactHash])
  @@map("blocked_contact_hashes")
}

// 6.7 — status/createdByUserId/approvals are new. For INDIVIDUAL profiles
// a trip is created straight into SCHEDULED (nothing to approve — there's
// only one member). For COUPLE/GROUP, creating a trip starts it at
// WAITING_MEMBER_APPROVAL: the creator alone cannot announce availability
// for the whole profile, matching the spec's explicit "não permitir um
// membro anunciar disponibilidade dos dois sozinho".
enum TravelModeStatus {
  WAITING_MEMBER_APPROVAL
  SCHEDULED
  CANCELLED
}

model TravelMode {
  id              String           @id @default(uuid())
  profileId       String
  profile         Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  city            String
  country         String?
  startDate       DateTime
  endDate         DateTime
  active          Boolean          @default(true)
  status          TravelModeStatus @default(SCHEDULED)
  createdByUserId String?
  createdAt       DateTime         @default(now())

  approvals TravelModeApproval[]

  // 5.11 — DiscoveryService's location/travel step (5.2 pipeline step 10)
  // looks up each candidate's active travel rows; before this TravelMode
  // had zero indexes and, more importantly, zero callers at all outside
  // its own CRUD routes.
  @@index([profileId, active])
  @@map("travel_modes")
}

// 6.7 — one row per required approver (every ACCEPTED ProfileMember at
// creation time), mirroring CoupleMatchApproval's shape. A trip only
// reaches SCHEDULED once every row here has approvedAt set.
model TravelModeApproval {
  id           String    @id @default(uuid())
  travelModeId String
  travelMode   TravelMode @relation(fields: [travelModeId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@unique([travelModeId, userId])
  @@map("travel_mode_approvals")
}

// 5.5 — CompatibilityScore: persisted, versioned score cache. Replaces
// "recompute Between Score on every discovery request, keep nothing"
// (the pre-Sprint-5 behavior) with a real cache that can be invalidated
// surgically (5.8) instead of thrown away wholesale.
//
// Deliberately DIRECTIONAL, not symmetric: sourceProfileId->targetProfileId
// and targetProfileId->sourceProfileId are two separate rows and CAN differ
// (e.g. REQUIRE_TARGET_ACCEPTANCE boundaries, or intention preferences that
// aren't mirrored on both sides) - this must never be assumed symmetric.
model CompatibilityScore {
  id               String    @id @default(uuid())
  sourceProfileId  String
  sourceProfile    Profile   @relation("CompatibilityScoreSource", fields: [sourceProfileId], references: [id], onDelete: Cascade)
  targetProfileId  String
  targetProfile    Profile   @relation("CompatibilityScoreTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)
  score            Int
  algorithmVersion String
  breakdown        Json
  reasons          Json
  calculatedAt     DateTime  @default(now())
  expiresAt        DateTime?

  @@unique([sourceProfileId, targetProfileId, algorithmVersion])
  @@index([targetProfileId])
  @@map("compatibility_scores")
}

// 5.6 — BETWEEN_SCORE_V2 weights, admin-editable, never hardcoded in a
// route. Same single-row-per-version pattern as ReferralRule. Weights are
// stored as 0-1 fractions and are expected to sum to 1.0, but that's a
// convention this table doesn't enforce at the DB level (validated by
// BetweenScoreConfigService instead) - matches how ReferralRule also
// trusts its own service layer rather than DB constraints for business
// rules.
model BetweenScoreConfig {
  id                        String   @id @default(uuid())
  algorithmVersion          String   @unique
  weightIntentions          Float    @default(0.30)
  weightBoundaries          Float    @default(0.30)
  weightRelationshipContext Float    @default(0.15)
  weightDiscretion          Float    @default(0.10)
  weightLocation            Float    @default(0.10)
  weightConversationPace    Float    @default(0.05)
  active                    Boolean  @default(true)
  updatedAt                 DateTime @updatedAt
  updatedByUserId           String?

  @@map("between_score_configs")
}

model AdminAction {
  id          String    @id @default(uuid())
  adminId     String
  admin       User      @relation("AdminPerformer", fields: [adminId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("AdminTarget", fields: [targetUserId], references: [id])
  targetType  String
  targetId    String
  action      String
  reason      String?
  internalNote String?
  previousData Json?
  newData      Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("admin_actions")
}

model BetaInvite {
  id          String    @id @default(uuid())
  code        String    @unique
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
  usedById    String?   @unique
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id])
  email       String?
  maxUses     Int       @default(1)
  useCount    Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  @@map("beta_invites")
}

model PhotoAccessRequest {
  id           String             @id @default(uuid())
  photoId      String
  photo        ProfilePhoto       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  requesterId  String
  ownerId      String
  status       PhotoAccessStatus  @default(PENDING)
  expiresAt    DateTime?
  respondedAt  DateTime?
  createdAt    DateTime           @default(now())

  // 6.8 — only populated/consulted for MULTIPLE_MEMBERS/SHARED_PROFILE
  // photos: one row per depicted member whose consent is required. For a
  // SINGLE_MEMBER photo (the pre-Sprint-6 default), this stays empty and
  // `status` alone still means what it always meant — the owner's own
  // decision, no per-member approval layer needed.
  approvals    PhotoAccessApproval[]

  @@unique([photoId, requesterId])
  @@map("photo_access_requests")
}

// 6.8 — mirrors CoupleMatchApproval/TravelModeApproval's shape: one row per
// required approver (each depicted member's user, resolved via
// ProfileMembershipService), the request's overall `status` only becomes
// APPROVED once every row here has approvedAt set (see
// sharedMediaConsentService.ts).
model PhotoAccessApproval {
  id                   String    @id @default(uuid())
  photoAccessRequestId String
  request              PhotoAccessRequest @relation(fields: [photoAccessRequestId], references: [id], onDelete: Cascade)
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedAt           DateTime?
  rejectedAt           DateTime?
  createdAt            DateTime  @default(now())

  @@unique([photoAccessRequestId, userId])
  @@map("photo_access_approvals")
}

// ─── Notifications ────────────────────────────────────────────────────────────
model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ─── Service Sessions (Moderator / Support shift tracking) ────────────────────
model ServiceSession {
  id          String    @id @default(uuid())
  userId      String
  role        String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationMin Int?
  notes       String?
  createdAt   DateTime  @default(now())

  @@map("service_sessions")
}

// ─── Guide Articles (Between Guide) ──────────────────────────────────────────
// ─── Referrals / Affiliate system ─────────────────────────────────────────────
model ReferralCode {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String   @unique
  createdAt   DateTime @default(now())

  conversions ReferralConversion[]

  @@map("referral_codes")
}

model ReferralConversion {
  id             String       @id @default(uuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredUserId String       @unique
  referredUser   User         @relation("ReferredUserConversion", fields: [referredUserId], references: [id], onDelete: Cascade)
  subscribedAt   DateTime?
  creditGranted  Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("referral_conversions")
}

// Singleton-style config row — editable in admin, never hardcoded in code.
model ReferralRule {
  id                String   @id @default(uuid())
  referralsRequired Int      @default(2)
  rewardMonths      Int      @default(2)
  updatedAt         DateTime @updatedAt
  updatedByUserId   String?

  @@map("referral_rules")
}

// ─── Gender catalog (Sprint 2.5.6) ────────────────────────────────────────────
// Profile.gender stays a free String (not a FK) to avoid a hard migration risk
// on existing data/custom values already stored — this is the admin-managed
// catalog of *suggested* options; the slug is what gets stored in Profile.gender.
model GenderOption {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String
  description String?
  localeKey   String?  // 4.3 — optional i18n key, for when client copy moves off hardcoded PT labels
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gender_options")
}

// 4.4 — same shape as GenderOption. orientation on Profile had zero UI to
// set it (state existed in the create/edit forms, but no <select> ever
// rendered it) — this plus the client wiring closes that gap.
model OrientationOption {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String
  description String?
  localeKey   String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("orientation_options")
}

model GuideArticle {
  id        String   @id @default(uuid())
  title     String
  category  String
  summary   String?
  body      String   @db.Text
  icon      String?  @default("○")
  published Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guide_articles")
}

// ─── Push Subscriptions (Web Push / PWA) ─────────────────────────────────────
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

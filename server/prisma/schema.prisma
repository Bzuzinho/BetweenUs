// Between Us — Prisma Schema v4
// Roles reais + AdminAction completo + ConsentCheck + novas features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  BANNED
  DELETED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
  FINANCE
  CONTENT_REVIEWER
}

enum ProfileType {
  INDIVIDUAL
  COUPLE
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  HIDDEN
  SUSPENDED
}

enum RelationshipStatus {
  SINGLE
  COMMITTED
  MARRIED
  OPEN
  POLYAMOROUS
  COUPLE_CURIOUS
  COUPLE_LIBERAL
  OTHER
}

enum DiscretionLevel {
  MAXIMUM
  SELECTIVE
  OPEN
}

enum ProfileVisibility {
  PUBLIC
  MATCHES_ONLY
  INVISIBLE
}

enum PhotoVisibility {
  PUBLIC
  BLURRED
  PRIVATE_AFTER_MATCH
  PRIVATE_AFTER_APPROVAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum BoundaryPreference {
  YES
  MAYBE
  NO
}

enum ActionType {
  LIKE
  PASS
  SUPER_LIKE
  BLOCK
  REPORT
}

enum MatchStatus {
  PENDING
  PENDING_COUPLE_APPROVAL
  ACTIVE
  PAUSED
  ENDED
  BLOCKED
}

enum CoupleStatus {
  PENDING_PARTNER
  ACTIVE
  PAUSED
  SEPARATED
  DISABLED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
  CONSENT_REQUEST
  PHOTO_UNLOCK_REQUEST
}

enum ConversationType {
  ONE_TO_ONE
  COUPLE_GROUP
  PRIVATE_ROOM
}

enum ReportReason {
  FAKE_PROFILE
  HARASSMENT
  OFFENSIVE_CONTENT
  MINOR
  NON_CONSENSUAL_IMAGE
  SPAM
  THREAT
  COERCION
  REVENGE_PORN
  DOXXING
  PROSTITUTION_OR_ESCORT
  PAID_SEXUAL_SERVICES
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
  ESCALATED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  COUPLE_PREMIUM
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIALING
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ConsentType {
  TERMS
  PRIVACY_POLICY
  SENSITIVE_DATA
  MARKETING
  LOCATION
  CONTACT_HASHING
}

enum NotificationMode {
  NORMAL
  DISCREET
  SILENT
}

enum ConsentCheckStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ConsentCheckPhase {
  MATCH
  CHAT
  PHOTO_REQUEST
  FACE_REVEAL
  VIDEO_CALL
  MEETING_PROPOSAL
  SAFETY_CHECKIN
}

enum PhotoAccessStatus {
  PENDING
  APPROVED
  DECLINED
  REVOKED
  EXPIRED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String
  emailVerifiedAt   DateTime?
  dateOfBirth       DateTime
  ageVerifiedAt     DateTime?
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  status            UserStatus @default(PENDING_VERIFICATION)
  adminRole         AdminRole?
  lastSeenAt        DateTime?
  riskScore         Int        @default(0)
  nif               String?    // NIF/contribuinte — account level, private
  accountName       String?    // Real name — private, different from displayName
  avatarPath        String?    // Account avatar URL
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  profile              Profile?
  consents             UserConsent[]
  subscription         Subscription?
  verification         Verification?
  blockedContacts      BlockedContactHash[]
  reportsMade          Report[]              @relation("ReporterUser")
  reportsReceived      Report[]              @relation("ReportedUser")
  messages             Message[]
  coupleApprovals      CoupleMatchApproval[]
  privateRoomMembers   PrivateRoomMember[]
  adminActionsPerformed AdminAction[]        @relation("AdminPerformer")
  adminActionsReceived  AdminAction[]        @relation("AdminTarget")
  betaInvites          BetaInvite[]         @relation("InviteCreator")
  betaInviteUsed       BetaInvite?          @relation("InviteUser")

  @@map("users")
}

model Profile {
  id                 String        @id @default(uuid())
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               ProfileType   @default(INDIVIDUAL)
  status             ProfileStatus @default(PENDING_REVIEW)
  displayName        String
  bio                String?
  gender             String?
  orientation        String?
  relationshipStatus RelationshipStatus @default(SINGLE)
  locationLat        Float?
  locationLng        Float?
  city               String?
  country            String?
  visibilityMode     ProfileVisibility @default(PUBLIC)
  discretionLevel    DiscretionLevel   @default(SELECTIVE)
  betweenScore       Int?
  rejectionReason    String?
  moderationNotes    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  coupleProfile    CoupleProfile?
  photos           ProfilePhoto[]
  intentions       ProfileIntention[]
  boundaries       ProfileBoundary[]
  privacySettings  PrivacySettings?
  actionsGiven     ProfileAction[]   @relation("ActionActor")
  actionsReceived  ProfileAction[]   @relation("ActionTarget")
  matchesAsOne     Match[]           @relation("MatchProfileOne")
  matchesAsTwo     Match[]           @relation("MatchProfileTwo")
  travelModes      TravelMode[]
  safetyCheckins   SafetyCheckin[]
  consentChecks    ConsentCheck[]

  @@map("profiles")
}

model CoupleProfile {
  id                    String       @id @default(uuid())
  profileId             String       @unique
  profile               Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  partnerOneUserId      String
  partnerTwoUserId      String?
  partnerTwoInviteEmail String?
  partnerTwoAcceptedAt  DateTime?
  coupleStatus          CoupleStatus @default(PENDING_PARTNER)
  coupleInviteToken     String?      @unique
  coupleDescription     String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("couple_profiles")
}

model ProfilePhoto {
  id               String           @id @default(uuid())
  profileId        String
  profile          Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  storagePath      String
  blurredPath      String?
  visibilityLevel  PhotoVisibility  @default(BLURRED)
  moderationStatus ModerationStatus @default(PENDING)
  moderationNotes  String?
  isPrimary        Boolean          @default(false)
  sortOrder        Int              @default(0)
  exifStripped     Boolean          @default(false)
  createdAt        DateTime         @default(now())

  accessRequests   PhotoAccessRequest[]

  @@map("profile_photos")
}

model Intention {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String?
  active      Boolean            @default(true)
  profiles    ProfileIntention[]

  @@map("intentions")
}

model ProfileIntention {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  intentionId String
  intention   Intention @relation(fields: [intentionId], references: [id])
  preference  BoundaryPreference @default(YES)

  @@unique([profileId, intentionId])
  @@map("profile_intentions")
}

model Boundary {
  id          String            @id @default(uuid())
  name        String
  category    String
  description String?
  profiles    ProfileBoundary[]

  @@map("boundaries")
}

model ProfileBoundary {
  id         String             @id @default(uuid())
  profileId  String
  profile    Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  boundaryId String
  boundary   Boundary           @relation(fields: [boundaryId], references: [id])
  preference BoundaryPreference

  @@unique([profileId, boundaryId])
  @@map("profile_boundaries")
}

model PrivacySettings {
  id                 String           @id @default(uuid())
  profileId          String           @unique
  profile            Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  visibleInDiscovery Boolean          @default(true)
  showDistance       Boolean          @default(true)
  showOnlineStatus   Boolean          @default(false)
  allowPhotoRequests Boolean          @default(true)
  invisibleMode      Boolean          @default(false)
  notificationMode   NotificationMode @default(DISCREET)
  minDistanceKm      Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("privacy_settings")
}

model ProfileAction {
  id              String     @id @default(uuid())
  actorProfileId  String
  actor           Profile    @relation("ActionActor", fields: [actorProfileId], references: [id], onDelete: Cascade)
  targetProfileId String
  target          Profile    @relation("ActionTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)
  action          ActionType
  createdAt       DateTime   @default(now())

  @@unique([actorProfileId, targetProfileId])
  @@map("profile_actions")
}

model Match {
  id           String      @id @default(uuid())
  profileOneId String
  profileOne   Profile     @relation("MatchProfileOne", fields: [profileOneId], references: [id], onDelete: Cascade)
  profileTwoId String
  profileTwo   Profile     @relation("MatchProfileTwo", fields: [profileTwoId], references: [id], onDelete: Cascade)
  status       MatchStatus @default(PENDING)
  matchedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  approvals    CoupleMatchApproval[]
  conversation Conversation?
  privateRoom  PrivateRoom?
  consentChecks ConsentCheck[]

  @@unique([profileOneId, profileTwoId])
  @@map("matches")
}

model CoupleMatchApproval {
  id         String    @id @default(uuid())
  matchId    String
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([matchId, userId])
  @@map("couple_match_approvals")
}

model Conversation {
  id        String           @id @default(uuid())
  matchId   String           @unique
  match     Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      ConversationType @default(ONE_TO_ONE)
  agreedRules String[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  sender         User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body           String?
  messageType    MessageType  @default(TEXT)
  expiresAt      DateTime?
  readAt         DateTime?
  deletedAt      DateTime?
  removedByAdmin Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model PrivateRoom {
  id        String              @id @default(uuid())
  matchId   String              @unique
  match     Match               @relation(fields: [matchId], references: [id], onDelete: Cascade)
  title     String?
  rules     String[]
  status    String              @default("active")
  createdAt DateTime            @default(now())
  members   PrivateRoomMember[]

  @@map("private_rooms")
}

model PrivateRoomMember {
  id            String      @id @default(uuid())
  privateRoomId String
  privateRoom   PrivateRoom @relation(fields: [privateRoomId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String      @default("member")
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?

  @@unique([privateRoomId, userId])
  @@map("private_room_members")
}

model ConsentCheck {
  id          String             @id @default(uuid())
  matchId     String
  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  phase       ConsentCheckPhase
  status      ConsentCheckStatus @default(PENDING)
  initiatedBy String
  respondedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())

  @@map("consent_checks")
}

model SafetyCheckin {
  id              String    @id @default(uuid())
  profileId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matchId         String?
  scheduledAt     DateTime
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  alertSent       Boolean   @default(false)
  locationHint    String?
  createdAt       DateTime  @default(now())

  @@map("safety_checkins")
}

model Report {
  id                String       @id @default(uuid())
  reporterUserId    String
  reporter          User         @relation("ReporterUser", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUserId    String?
  reportedUser      User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reportedMessageId String?
  reason            ReportReason
  details           String?
  status            ReportStatus @default(PENDING)
  priority          Int          @default(0)
  internalNotes     String?
  createdAt         DateTime     @default(now())
  reviewedAt        DateTime?

  @@map("reports")
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider               String             @default("stripe")
  providerCustomerId     String?
  providerSubscriptionId String?
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("subscriptions")
}

model Verification {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               String             @default("selfie")
  status             VerificationStatus @default(PENDING)
  provider           String?
  selfieStoragePath  String?            // URL of the selfie in R2 — deleted after review
  reviewedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())

  @@map("verifications")
}

model UserConsent {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType ConsentType
  version     String
  acceptedAt  DateTime    @default(now())
  revokedAt   DateTime?
  // T4: RGPD audit trail — required for accountability
  ipAddress   String?
  userAgent   String?

  @@map("user_consents")
}

model BlockedContactHash {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactHash String
  type        String
  createdAt   DateTime @default(now())

  @@unique([userId, contactHash])
  @@map("blocked_contact_hashes")
}

model TravelMode {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  city      String
  country   String?
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("travel_modes")
}

model AdminAction {
  id          String    @id @default(uuid())
  adminId     String
  admin       User      @relation("AdminPerformer", fields: [adminId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("AdminTarget", fields: [targetUserId], references: [id])
  targetType  String
  targetId    String
  action      String
  reason      String?
  internalNote String?
  previousData Json?
  newData      Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("admin_actions")
}

model BetaInvite {
  id          String    @id @default(uuid())
  code        String    @unique
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
  usedById    String?   @unique
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id])
  email       String?
  maxUses     Int       @default(1)
  useCount    Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  @@map("beta_invites")
}

model PhotoAccessRequest {
  id           String             @id @default(uuid())
  photoId      String
  photo        ProfilePhoto       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  requesterId  String
  ownerId      String
  status       PhotoAccessStatus  @default(PENDING)
  expiresAt    DateTime?
  respondedAt  DateTime?
  createdAt    DateTime           @default(now())

  @@unique([photoId, requesterId])
  @@map("photo_access_requests")
}

// ─── Notifications ────────────────────────────────────────────────────────────
model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ─── Service Sessions (Moderator / Support shift tracking) ────────────────────
model ServiceSession {
  id          String    @id @default(uuid())
  userId      String
  role        String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationMin Int?
  notes       String?
  createdAt   DateTime  @default(now())

  @@map("service_sessions")
}

// ─── Guide Articles (Between Guide) ──────────────────────────────────────────
model GuideArticle {
  id        String   @id @default(uuid())
  title     String
  category  String
  summary   String?
  body      String   @db.Text
  icon      String?  @default("○")
  published Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guide_articles")
}

// ─── Push Subscriptions (Web Push / PWA) ─────────────────────────────────────
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}
